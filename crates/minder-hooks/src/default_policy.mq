# Baseline safety net, active even with no project hooks. Loaded before any
# user hook file, so redefining `on_tool_call` fully replaces it -- call
# `default_on_tool_call(call)` from your own version to keep these checks too.
#
# The checks themselves are data (`default_denylist()` below), not an
# if/elif chain -- adding a new blocked command/path is appending a rule, not
# writing new mq logic. `default_on_tool_call_with(call, extra_rules)` lets a
# project hook layer its own rules, in the same shape, on top of these.

def default_arg(call, key): call["arguments"][key];

def default_arg_str(call, key):
  let v = default_arg(call, key)
  | if (is_string(v)): v else: "";

# One matcher per `"match"` kind a rule can use below. Add a new kind (e.g.
# `"regex"`) by adding an entry here -- every rule using it picks it up, no
# dispatch code to touch.
def default_matchers():
  {
    "contains": fn(haystack, needle): contains(haystack, needle) end,
    "path_segment": fn(haystack, needle): contains(split(haystack, "/"), needle) end,
  };

# Each rule: `{"match": <key into default_matchers()>, "arg_keys": [...],
# "needle": "...", "reason": "..."}`. A rule matches a call if any of its
# `arg_keys` (as a string, missing/non-string args never match) satisfies
# `matcher(arg_value, needle)`.
def default_denylist():
  [
    {
      "match": "contains",
      "arg_keys": ["command"],
      "needle": "rm -rf",
      "reason": "destructive command blocked by default policy (rm -rf)",
    },
    {
      "match": "contains",
      "arg_keys": ["path", "pattern", "command"],
      "needle": ".env",
      "reason": ".env is excluded by default policy",
    },
    {
      "match": "contains",
      "arg_keys": ["path", "pattern", "command"],
      "needle": "node_modules",
      "reason": "node_modules is excluded by default policy",
    },
    {
      "match": "path_segment",
      "arg_keys": ["path", "pattern"],
      "needle": ".git",
      "reason": ".git is excluded by default policy",
    },
  ];

def default_rule_matches(call, rule):
  let matcher = get_or(default_matchers(), rule["match"], fn(_haystack, _needle): false end)
  | any(rule["arg_keys"], fn(key): matcher(default_arg_str(call, key), rule["needle"]) end);

def default_apply_rules(call, rules):
  let hit = find_index(rules, fn(rule): default_rule_matches(call, rule) end)
  | if (hit == -1): {"action": "allow", "value": call} else: {"action": "block", "reason": rules[hit]["reason"]};

# For a project hook that wants to add rules without rewriting `on_tool_call`
# from scratch, e.g.:
#   def on_tool_call(call):
#     default_on_tool_call_with(call, [
#       {"match": "contains", "arg_keys": ["command"], "needle": "| sh", "reason": "no piping to a shell"},
#     ]);
def default_on_tool_call_with(call, extra_rules): default_apply_rules(call, default_denylist() + extra_rules);

def default_on_tool_call(call): default_on_tool_call_with(call, []);

def on_tool_call(call): default_on_tool_call(call);
